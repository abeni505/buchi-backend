# --- Database Configuration ---
# For local development (outside Docker), use: mongodb://localhost:27017
# For Docker, use the service name defined in docker-compose.yml
MONGO_URL=mongodb://mongo:27017

# --- External API Keys ---
# Get your API key from https://rescuegroups.org/services/request-an-api-key/
RESCUE_GROUPS_API_KEY=your_api_key_here
